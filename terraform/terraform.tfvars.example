# =============================================================================
# Example tfvars — copy to terraform.tfvars and fill in project_id.
#   cp terraform.tfvars.example terraform.tfvars
# Every other variable below already has a working default (see
# variables.tf) so, for a brand-new/empty project, this one line is enough
# for a one-shot `terraform apply`.
# =============================================================================

# REQUIRED — the only value you must set. No default on purpose (see
# variables.tf) so a one-shot deploy never lands in the wrong project.
project_id = "your-gcp-project-id"

# --- Everything below is OPTIONAL — uncomment only to override a default ---

# region              = "us-central1"        # provider-level default region
# bq_location         = "US"                 # BigQuery multi-region for all datasets/connection/model
# dashboard_dataset_id = "gemini_ent_dashboard"
# analytics_dataset_id = "gemini_ent_analytics"
# log_bucket_name      = "_Default"
# log_bucket_location  = "global"
# connection_id        = "gemini_conn"
# model_name            = "gemini_flash"
# gemini_endpoint       = "gemini-2.5-flash-lite"  # cheapest verified-working endpoint on this project family

# --- Opt-in: prompt/response text + real user IDs in the logs --------------

# Makes questions, answers, and userIamPrincipal land in the logs as plain
# text instead of "<elided>". Without it, v_user_questions is empty and every
# per-user view collapses onto one masked user.
#
# *** FORWARD-ONLY: enabling this later does NOT backfill. *** Logs already
# written masked stay masked forever, so decide BEFORE the first deploy.
#
# Defaults to false because it writes end-user PII in the clear into Cloud
# Logging and, via the linked dataset, into BigQuery. Lock down IAM on both
# datasets first. See sensitive_logging.tf.
# enable_sensitive_logging = false

# Which engines to apply the above to.
#   Empty (default) = AUTO: unmask only engines that are ALREADY logging
#     (observabilityEnabled=true). Nothing new starts logging; no new bill.
#     Engines with observability off are listed and skipped.
#   Explicit list   = force observability + sensitive logging ON for these
#     engines, i.e. start logging an app that was not logging before. Use for
#     a fresh app that has never had observability turned on.
# sensitive_logging_engine_ids = ["my-app_1782188315701"]

# How far back the CHART views read from the archive. Default 90 days.
# The archive keeps everything regardless — this only bounds what charts scan,
# so their cost stays flat instead of growing as the archive ages. Use
# v_log_source_all for ad-hoc queries that need older history. 0 = unbounded.
# dashboard_window_days = 90

# --- Opt-in: durable log archive -------------------------------------------

# _AllLogs is a VIEW over the _Default log bucket (0 bytes of its own), so the
# bucket's retention (30 days by default) is the hard limit on how far back ANY
# view can see, and expired logs are gone — there is no backfill. These two
# flags keep a real partitioned copy (t_logs_archive) that outlives retention.
#
# Storage is negligible (~11 MB / 38 days — only the logs the views read).
# Opt-in for governance: with enable_sensitive_logging on, archived rows hold
# end-user prompts in the clear, so this makes that PII outlive retention.
#
# START EARLY — the archive can only save what the bucket still holds.
# enable_log_archive       = false   # one-shot: create table + backfill
# enable_scheduled_archive = false   # daily incremental (without it, snapshot goes stale)

# Schedule for the above. UTC, no timezone param.
# "every day 17:00" = 02:00 KST, one hour before the classifier reads the logs.
# archive_schedule = "every day 17:00"

# --- Opt-in, cost-incurring flags (both default to false) ------------------

# Runs sql/02_content_classification.sql once per `terraform apply` (Gemini
# call per unclassified row). Leave false unless you deliberately want a
# one-shot classification pass this apply.
# enable_content_classification = false

# Creates a recurring (see scheduled_query_schedule) BigQuery Data Transfer
# Service scheduled query that re-runs sql/02_content_classification.sql
# automatically, keeping t_content_topics fresh without manual re-runs.
# WARNING: an equivalent scheduled query already exists in some projects,
# created manually — read scheduled_query.tf before enabling this to avoid a
# duplicate, double-billed schedule.
# enable_scheduled_classification = false

# Schedule for the above, in BigQuery Data Transfer Service syntax. Evaluated
# in UTC (no timezone param) — "every day 18:00" = 18:00 UTC = 03:00 KST.
# scheduled_query_schedule = "every day 18:00"

# Service account email the scheduled query runs as. Empty = BQ Data
# Transfer Service default behavior (no impersonation).
# scheduled_query_service_account = ""
